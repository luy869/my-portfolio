---
import { profile } from "../data/site";
---
<header class="w-full flex items-center justify-between py-2 border-b border-[var(--color-border-default)] mb-4">
  <div class="flex items-center gap-3">
    <div class="w-2 h-6 bg-[var(--color-neon-cyan)] animate-pulse"></div>
    <a href="/" class="font-mono font-bold text-lg text-white hover:text-[var(--color-neon-cyan)] transition-colors tracking-widest uppercase">
      {profile.handle}
    </a>
  </div>

  <nav class="hidden md:flex gap-6 items-center font-mono text-xs tracking-widest text-[var(--color-text-secondary)]">
    <a href="#" class="hover:text-white transition-colors relative group">
      [01] PROJECTS
      <span class="absolute -bottom-1 left-0 w-0 h-px bg-[var(--color-neon-cyan)] group-hover:w-full transition-all"></span>
    </a>
    <a href="#" class="hover:text-white transition-colors relative group">
      [02] SKILLS
      <span class="absolute -bottom-1 left-0 w-0 h-px bg-[var(--color-neon-cyan)] group-hover:w-full transition-all"></span>
    </a>
    <a href="#" class="hover:text-white transition-colors relative group">
      [03] EXPERIENCE
      <span class="absolute -bottom-1 left-0 w-0 h-px bg-[var(--color-neon-cyan)] group-hover:w-full transition-all"></span>
    </a>
  </nav>

  <div class="font-mono text-[10px] text-[var(--color-text-muted)] border border-[var(--color-border-default)] px-2 py-1 rounded">
    STATUS: <span class="text-[var(--color-neon-cyan)]">ONLINE</span>
  </div>
</header>
