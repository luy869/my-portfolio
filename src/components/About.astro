---
import SectionHeading from "./ui/SectionHeading.astro";
import { about } from "../data/site";
---

<section id="about" data-fade class="scroll-mt-24 py-16">
  <div class="mx-auto max-w-6xl px-8">
    <SectionHeading title="About" />

    <div class="grid items-start gap-10 lg:grid-cols-2">
      <div class="space-y-4">
        {about.paragraphs.map((p) => (
          <p class="text-sm leading-relaxed text-text-secondary">{p}</p>
        ))}
      </div>

      <div class="space-y-3">
        {about.highlights.map((item) => (
          <div class="rounded-lg border-l-2 border-accent bg-bg-secondary p-4">
            <p class="mb-1 text-xs font-semibold tracking-wider text-accent">
              {item.label}
            </p>
            <p class="text-sm text-text-primary">{item.value}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
