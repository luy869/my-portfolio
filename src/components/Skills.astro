---
import CyberBentoCard from "./ui/CyberBentoCard.astro";
import { skills } from "../data/site";

// カテゴリごとのネオンカラー
const categoryColors: Record<string, 'cyan' | 'magenta' | 'yellow'> = {
  "Backend / CLI": "cyan",
  "AI / LLM":     "magenta",
  "Infrastructure": "yellow",
  "Frontend / Web": "cyan",
  "Tools":         "magenta",
};
---

{skills.map((category) => {
  const glow = categoryColors[category.category] ?? 'cyan';
  let colorVar = "var(--color-neon-cyan)";
  if (glow === 'magenta') colorVar = "var(--color-neon-magenta)";
  if (glow === 'yellow') colorVar = "#f5ff50";

  return (
    <CyberBentoCard glowColor={glow} className="flex flex-col gap-4 !p-6 min-h-[160px]">
      <div class="flex items-center gap-2 mb-2 z-10">
        <span class="text-xl font-bold font-mono" style={`color: ${colorVar}`}>_</span>
        <h3 class="text-sm font-mono tracking-[0.2em] font-bold text-white uppercase drop-shadow-md">
          {category.category}
        </h3>
      </div>
      
      <div class="flex flex-wrap gap-2 z-10">
        {category.items.map((item) => (
          <span class="inline-flex items-center rounded bg-[var(--color-bg-base)]/50 px-2 py-1 text-xs font-mono font-semibold text-[var(--color-text-primary)] border border-[var(--color-border-default)] backdrop-blur-md shadow-sm">
            {item}
          </span>
        ))}
      </div>
    </CyberBentoCard>
  );
})}
