---
import SectionHeading from "./ui/SectionHeading.astro";
import SkillBadge from "./ui/SkillBadge.astro";
import { skills } from "../data/site";
---

<section id="skills" data-fade class="scroll-mt-24 bg-bg-secondary py-16">
  <div class="mx-auto max-w-6xl px-8">
    <SectionHeading title="Skills" />

    <div class="grid gap-8 sm:grid-cols-2 md:grid-cols-3 xl:grid-cols-5">
      {
        skills.map((category) => (
          <div>
            <h3 class="mb-3 text-xs font-semibold uppercase tracking-wider text-accent">
              {category.category}
            </h3>
            <div class="flex flex-wrap gap-1.5">
              {category.items.map((item) => (
                <SkillBadge text={item} />
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
