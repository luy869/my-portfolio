---
import CyberBentoCard from "./ui/CyberBentoCard.astro";
import { profile, socialLinks } from "../data/site";
---

<!-- =======================
  1. Main Greeting (2x2)
======================== -->
<CyberBentoCard glowColor="cyan" className="col-span-1 md:col-span-2 lg:col-span-2 row-span-2 flex flex-col justify-between p-8 relative overflow-hidden group">
  <div class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/diagonal-striped-brick.png')] opacity-10 pointer-events-none group-hover:opacity-20 transition-opacity"></div>
  
  <div class="z-10 mt-2">
    <div class="inline-flex items-center gap-2 mb-6 border border-[var(--color-border-neon)] bg-[var(--color-neon-cyan-dim)] px-3 py-1.5 rounded-full">
      <div class="w-2 h-2 rounded-full bg-[var(--color-neon-cyan)] animate-pulse"></div>
      <span class="font-mono text-xs text-[var(--color-neon-cyan)] font-semibold uppercase tracking-widest">System Online</span>
    </div>
    
    <h1 class="text-4xl lg:text-5xl font-bold tracking-tight text-white mb-2 font-mono">
      <span class="text-[var(--color-neon-magenta)]">&gt;</span> Hello_
    </h1>
    <h2 class="text-3xl lg:text-4xl font-bold tracking-tight text-white mb-4">
      I'm <span class="text-transparent bg-clip-text bg-gradient-to-r from-[var(--color-neon-cyan)] to-[var(--color-neon-magenta)]">{profile.name}</span>
    </h2>
    <p class="text-[var(--color-text-secondary)] text-sm md:text-base max-w-md leading-relaxed mt-4">
      Computer Science Student / Software Engineer.<br/>
      Turning coffee into <span class="text-[var(--color-neon-cyan)]">glassmorphism</span> & <span class="text-[var(--color-neon-magenta)]">AI apps</span>.
    </p>
  </div>
  
  <div class="z-10 mt-auto pt-8">
    <div class="font-mono text-sm text-[var(--color-text-muted)] flex items-center gap-2">
      <span class="text-[var(--color-neon-cyan)]">$</span>
      <span class="typing-effect overflow-hidden whitespace-nowrap border-r-2 border-[var(--color-neon-cyan)] pr-1">whoami --verbose</span>
    </div>
  </div>
</CyberBentoCard>

<!-- =======================
  2. Avatar Image (1x2)
======================== -->
<CyberBentoCard glowColor="magenta" className="col-span-1 md:col-span-2 lg:col-span-1 row-span-1 lg:row-span-2 !p-0 overflow-hidden relative group">
  <!-- スマホ・タブレットではただの横長カード、PCでは縦長に -->
  <div class="w-full h-full min-h-[200px] bg-cover bg-center transition-transform duration-700 group-hover:scale-105" style={`background-image: url('${profile.avatarUrl}');`}>
    <div class="absolute inset-0 bg-gradient-to-t from-[var(--color-bg-card)] via-transparent to-transparent"></div>
    <div class="absolute inset-0 bg-[var(--color-neon-cyan)] opacity-10 mix-blend-overlay group-hover:opacity-0 transition-opacity"></div>
  </div>
  <div class="absolute bottom-4 left-4 border border-[var(--color-border-neon)] bg-[var(--color-bg-card)]/80 backdrop-blur-sm px-3 py-1 rounded font-mono text-xs text-white opacity-0 group-hover:opacity-100 transition-opacity translate-y-2 group-hover:translate-y-0">
    <span class="text-[var(--color-neon-cyan)]">ID:</span> {profile.handle}
  </div>
</CyberBentoCard>

<!-- =======================
  3. About Snippet (2x1 on PC)
======================== -->
<CyberBentoCard glowColor="yellow" className="col-span-1 md:col-span-2 lg:col-span-2 row-span-1 flex flex-col justify-center gap-3">
  <div class="flex items-center gap-2 mb-2">
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" class="stroke-[var(--color-neon-yellow)]" stroke-width="2">
      <path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
    </svg>
    <span class="text-xs font-mono text-white opacity-70 uppercase tracking-widest">Base</span>
  </div>
  <p class="text-sm font-medium text-white flex items-center justify-between">
    <span>Tokyo, Japan</span>
    <span class="flex items-center gap-2">
      <span class="w-1.5 h-1.5 rounded-full bg-green-500 animate-pulse"></span>
      <span class="text-xs text-[var(--color-text-secondary)] font-mono">Available</span>
    </span>
  </p>
  
  <div class="w-full h-px bg-[var(--color-border-default)] my-1"></div>
  
  <p class="text-xs text-[var(--color-text-secondary)] line-clamp-2 md:line-clamp-1">
    {profile.bio}
  </p>
</CyberBentoCard>

<!-- =======================
  4. Social Link 1: GitHub (1x1)
======================== -->
<CyberBentoCard href={socialLinks[0]?.url || "#"} glowColor="cyan" className="col-span-1 md:col-span-1 lg:col-span-1 row-span-1 flex items-center justify-center group bg-gradient-to-br from-[var(--color-bg-card)] to-[var(--color-bg-elevated)] min-h-[140px]">
  <div class="flex flex-col items-center gap-3">
    <div class="w-12 h-12 rounded-full border border-[var(--color-border-default)] group-hover:border-[var(--color-neon-cyan)] flex items-center justify-center transition-colors bg-[var(--color-bg-base)]">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" class="stroke-[var(--color-text-primary)] group-hover:stroke-[var(--color-neon-cyan)] transition-colors" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path>
      </svg>
    </div>
    <span class="text-xs font-mono font-semibold text-[var(--color-text-secondary)] group-hover:text-white transition-colors">GitHub</span>
  </div>
</CyberBentoCard>

<!-- =======================
  5. Social Link 2: Zenn (1x1)
======================== -->
<CyberBentoCard href={socialLinks[1]?.url || "#"} glowColor="magenta" className="col-span-1 md:col-span-1 lg:col-span-1 row-span-1 flex items-center justify-center group bg-gradient-to-br from-[var(--color-bg-card)] to-[var(--color-bg-elevated)] min-h-[140px]">
  <div class="flex flex-col items-center gap-3">
    <div class="w-12 h-12 rounded-full border border-[var(--color-border-default)] group-hover:border-[var(--color-neon-magenta)] flex items-center justify-center transition-colors bg-[var(--color-bg-base)]">
      <!-- Zennの簡単なアイコン代用（ペンみたいなマーク） -->
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" class="stroke-[var(--color-text-primary)] group-hover:stroke-[var(--color-neon-magenta)] transition-colors" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 19l7-7 3 3-7 7-3-3z"></path>
        <path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"></path>
        <path d="M2 2l7.58 7.58"></path>
        <circle cx="11" cy="11" r="2"></circle>
      </svg>
    </div>
    <span class="text-xs font-mono font-semibold text-[var(--color-text-secondary)] group-hover:text-white transition-colors">Zenn.dev</span>
  </div>
</CyberBentoCard>

<style>
  .typing-effect {
    animation: typing 3s steps(30, end) infinite;
  }
  @keyframes typing {
    0% { width: 0; }
    50% { width: 100%; }
    100% { width: 100%; } 
  }
</style>
