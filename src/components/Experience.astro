---
import SectionHeading from "./ui/SectionHeading.astro";
import { experience } from "../data/site";
---

<section id="experience" data-fade class="experience-section scroll-mt-24">
  <div class="section-container">
    <SectionHeading title="Experience" />

    <div class="exp-track-wrapper">
      <!-- 横スクロールコンテナ -->
      <div class="exp-track" id="exp-track">
        {experience.map((item, i) => (
          <div class="exp-card">
            <!-- カード番号 -->
            <div class="exp-num">
              <span class="terminal-prefix">{String(i + 1).padStart(2, "0")}</span>
            </div>

            <!-- コーナーデコ -->
            <span class="exp-corner exp-corner-tl" aria-hidden="true"></span>
            <span class="exp-corner exp-corner-br" aria-hidden="true"></span>

            <div class="exp-inner">
              <!-- 期間 -->
              {item.period && (
                <div class="exp-period">
                  <span class="period-bar" aria-hidden="true"></span>
                  <span class="period-text">{item.period}</span>
                </div>
              )}

              <!-- タイトル & ロール -->
              <h3 class="exp-title">{item.title}</h3>
              <p class="exp-role">{item.role}</p>

              <!-- 説明 -->
              {item.description && (
                <p class="exp-desc">{item.description}</p>
              )}
            </div>
          </div>
        ))}

        <!-- フェードアウト用ダミー -->
        <div class="exp-fade-guard" aria-hidden="true"></div>
      </div>

      <!-- スクロールヒント -->
      <div class="scroll-hint" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
        <span>scroll</span>
      </div>
    </div>
  </div>
</section>

<style>
  .experience-section {
    padding-block: 6rem;
    background: linear-gradient(
      180deg,
      var(--color-bg-base) 0%,
      var(--color-bg-surface) 100%
    );
  }

  /* ========== 横スクロールトラック ========== */
  .exp-track-wrapper {
    position: relative;
  }

  .exp-track {
    display: flex;
    gap: 1.25rem;
    overflow-x: auto;
    padding-bottom: 1rem;
    padding-right: 2rem;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: thin;
    scrollbar-color: rgba(0, 255, 213, 0.3) transparent;
  }

  .exp-track::-webkit-scrollbar {
    height: 2px;
  }

  .exp-track::-webkit-scrollbar-thumb {
    background: rgba(0, 255, 213, 0.3);
    border-radius: 9999px;
  }

  /* ========== カード ========== */
  .exp-card {
    position: relative;
    flex-shrink: 0;
    width: min(320px, 80vw);
    background: var(--color-bg-card);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 4px;
    overflow: hidden;
    scroll-snap-align: start;
    transition: border-color 0.3s ease;
  }

  .exp-card:hover {
    border-color: rgba(0, 255, 213, 0.2);
  }

  .exp-card:hover .exp-corner {
    opacity: 1;
  }

  /* コーナーデコ */
  .exp-corner {
    position: absolute;
    width: 8px;
    height: 8px;
    opacity: 0;
    transition: opacity 0.3s;
    pointer-events: none;
  }

  .exp-corner-tl {
    top: -1px; left: -1px;
    border-top: 1px solid var(--color-neon-cyan);
    border-left: 1px solid var(--color-neon-cyan);
  }

  .exp-corner-br {
    bottom: -1px; right: -1px;
    border-bottom: 1px solid var(--color-neon-cyan);
    border-right: 1px solid var(--color-neon-cyan);
  }

  .exp-num {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--color-text-muted);
    opacity: 0.5;
  }

  .exp-inner {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    height: 100%;
  }

  /* 期間 */
  .exp-period {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .period-bar {
    display: block;
    width: 16px;
    height: 1px;
    background: var(--color-neon-cyan);
    box-shadow: 0 0 6px rgba(0, 255, 213, 0.4);
  }

  .period-text {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--color-neon-cyan);
    opacity: 0.8;
    letter-spacing: 0.04em;
  }

  /* タイトル */
  .exp-title {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-text-primary);
    letter-spacing: -0.01em;
    line-height: 1.3;
  }

  /* ロール */
  .exp-role {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--color-neon-magenta);
    text-shadow: 0 0 8px rgba(255, 0, 170, 0.3);
    line-height: 1.4;
  }

  /* 説明 */
  .exp-desc {
    font-size: 0.78rem;
    line-height: 1.75;
    color: var(--color-text-muted);
    flex: 1;
  }

  /* スペーサー */
  .exp-fade-guard {
    flex-shrink: 0;
    width: 1px;
  }

  /* スクロールヒント */
  .scroll-hint {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    margin-top: 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--color-text-muted);
    opacity: 0.5;
  }

  @media (min-width: 1000px) {
    .scroll-hint { display: none; }
  }
</style>
