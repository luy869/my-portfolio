---
import SectionHeading from "./ui/SectionHeading.astro";
import { experience } from "../data/site";
---

<section id="experience" data-fade class="scroll-mt-24 py-16">
  <div class="mx-auto max-w-6xl px-8">
    <SectionHeading title="Experience" />

    <div class="relative">
      <div class="absolute left-[7px] top-1 bottom-1 hidden w-px bg-border-default sm:block" aria-hidden="true" />

      <div class="space-y-0">
        {
          experience.map((item) => (
            <div class="relative pb-8 last:pb-0 sm:pl-10">
              <div class="absolute left-0 top-1.5 hidden h-[15px] w-[15px] rounded-full border-2 border-accent bg-bg-primary sm:block" aria-hidden="true" />

              <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1">
                <h3 class="text-sm font-semibold text-text-primary">{item.title}</h3>
                {item.period && (
                  <span class="text-xs text-text-muted">{item.period}</span>
                )}
              </div>
              <p class="mt-1 text-sm font-medium text-accent">{item.role}</p>
              {item.description && (
                <p class="mt-3 text-sm leading-relaxed text-text-muted">{item.description}</p>
              )}
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
