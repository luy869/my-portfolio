---
import CyberBentoCard from "./ui/CyberBentoCard.astro";
import { experience } from "../data/site";
---

<CyberBentoCard glowColor="none" className="col-span-1 lg:col-span-3 !p-0">
  <!-- グラスモーフィズムのリストコンテナ -->
  <div class="relative w-full overflow-hidden flex flex-col divide-y divide-[var(--color-border-default)]">
    {experience.map((item, index) => (
      <div class="group relative flex flex-col md:flex-row items-baseline gap-4 p-6 md:p-8 hover:bg-[var(--color-neon-cyan-dim)] transition-colors">
        
        <!-- Hover indicator line -->
        <div class="absolute left-0 top-0 bottom-0 w-1 bg-[var(--color-neon-cyan)] opacity-0 group-hover:opacity-100 transition-opacity"></div>
        
        <!-- Period -->
        <div class="w-full md:w-1/4 shrink-0">
          <div class="text-[var(--color-neon-cyan)] font-mono text-xs uppercase tracking-widest mb-1 flex items-center gap-2">
            <span class="w-2 h-px bg-[var(--color-neon-cyan)]"></span>
            {item.period}
          </div>
        </div>
        
        <!-- Content -->
        <div class="w-full md:w-3/4">
          <h3 class="text-white font-bold text-lg mb-1 drop-shadow-md group-hover:text-[var(--color-neon-cyan)] transition-colors">{item.title}</h3>
          <p class="text-[var(--color-neon-magenta)] font-mono text-xs mb-3 font-semibold">{item.role}</p>
          {item.description && (
            <p class="text-[var(--color-text-secondary)] text-sm leading-relaxed max-w-2xl group-hover:text-white transition-colors">
              {item.description}
            </p>
          )}
        </div>
      </div>
    ))}
  </div>
</CyberBentoCard>
