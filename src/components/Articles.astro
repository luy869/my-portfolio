---
import CyberBentoCard from "./ui/CyberBentoCard.astro";

interface ZennArticle {
  title: string;
  slug: string;
  published_at: string;
  liked_count: number;
  emoji: string;
}

let articles: ZennArticle[] = [];
try {
  const res = await fetch("https://zenn.dev/api/articles?username=luy849&order=latest");
  const data = await res.json();
  articles = data.articles ?? [];
} catch {
  // フォーバック
}

function formatDate(dateStr: string) {
  const d = new Date(dateStr);
  return `${d.getFullYear()}.${String(d.getMonth() + 1).padStart(2, "0")}`;
}
---

{articles.length > 0 && articles.slice(0, 3).map((article) => (
  <CyberBentoCard href={`https://zenn.dev/luy849/articles/${article.slug}`} glowColor="yellow" className="group flex flex-col justify-between h-full !p-6 aspect-square sm:aspect-auto sm:min-h-[220px]">
    
    <div class="z-10 relative">
      <div class="text-4xl mb-4 group-hover:scale-110 transition-transform origin-bottom-left inline-block">
        {article.emoji}
      </div>
      <h3 class="text-base font-bold tracking-tight text-[var(--color-text-primary)] leading-snug line-clamp-3 group-hover:text-[#f5ff50] transition-colors shadow-black">
        {article.title}
      </h3>
    </div>
    
    <div class="z-10 mt-6 flex items-center justify-between border-t border-[var(--color-border-default)] pt-4 text-[var(--color-text-muted)] group-hover:text-white transition-colors">
      <span class="text-xs font-mono tracking-wider">{formatDate(article.published_at)}</span>
      <span class="flex items-center gap-1.5 text-xs font-mono font-bold">
        <svg class="h-3 w-3 fill-current" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z" clip-rule="evenodd"></path>
        </svg>
        {article.liked_count}
      </span>
    </div>
    
  </CyberBentoCard>
))}

<!-- Zennリンク用カード（4枠目） -->
<CyberBentoCard href="https://zenn.dev/luy849" glowColor="cyan" className="group flex flex-col items-center justify-center gap-4 !p-6 aspect-square sm:aspect-auto sm:min-h-[220px] bg-[url('data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSI0IiBoZWlnaHQ9IjQiPgo8cmVjdCB3aWR0aD0iNCIgaGVpZ2h0PSI0IiBmaWxsPSIjZmZmIiBmaWxsLW9wYWNpdHk9IjAuMDUiLz4KPC9zdmc+')]">
  <div class="z-10 flex flex-col items-center">
    <div class="w-12 h-12 rounded-full border border-[var(--color-border-neon)] flex items-center justify-center group-hover:bg-[var(--color-neon-cyan-dim)] transition-colors mb-3">
      <span class="text-[var(--color-neon-cyan)] font-mono font-bold">&gt;</span>
    </div>
    <span class="text-sm font-mono text-center text-white tracking-widest uppercase">Visit<br/>Zenn.dev</span>
  </div>
</CyberBentoCard>
