---
import { profile, socialLinks } from "../data/site";
---

<footer class="mt-auto border-t border-border-subtle">
  <div class="mx-auto flex max-w-6xl flex-col items-center gap-3 px-8 py-10 sm:flex-row sm:justify-between">
    <p class="text-xs text-text-muted">
      &copy; {new Date().getFullYear()} {profile.name}
    </p>
    <div class="flex items-center gap-4">
      {socialLinks.map((link) => (
        <a
          href={link.url}
          target="_blank"
          rel="noopener"
          class="text-xs text-text-muted transition-colors hover:text-accent"
        >
          {link.label}
        </a>
      ))}
    </div>
  </div>
</footer>
