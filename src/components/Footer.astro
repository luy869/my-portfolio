---
import { profile, socialLinks } from "../data/site";
const year = new Date().getFullYear();
---

<footer class="w-full py-8 mt-12 border-t border-[var(--color-border-default)] flex flex-col md:flex-row items-center justify-between font-mono text-xs text-[var(--color-text-muted)]">
  <div class="flex items-center gap-4 mb-4 md:mb-0">
    <span>&copy; {year} {profile.handle}.</span>
    
    <!-- イースターエッグ起動用の３点ドット -->
    <div class="flex items-center gap-1.5">
      <span class="text-[var(--color-neon-cyan)]">EOF</span>
      <button id="secret-btn" class="flex gap-1 p-1 opacity-50 hover:opacity-100 transition-opacity cursor-pointer group bg-transparent border-none">
        <span class="w-1 h-1 rounded-full bg-[var(--color-text-muted)] group-hover:bg-[var(--color-neon-cyan)] transition-colors"></span>
        <span class="w-1 h-1 rounded-full bg-[var(--color-text-muted)] group-hover:bg-[var(--color-neon-cyan)] transition-colors"></span>
        <span class="w-1 h-1 rounded-full bg-[var(--color-text-muted)] group-hover:bg-[var(--color-neon-cyan)] transition-colors"></span>
      </button>
    </div>

    <!-- 引き出されるゲームリンクたち（デフォルト非表示） -->
    <div class="flex items-center gap-2">
      <a
        id="gravity-btn"
        href="/gravity-wars.html"
        class="hidden items-center gap-1.5 px-2 py-0.5 border border-[var(--color-neon-cyan)] text-[var(--color-neon-cyan)] bg-[var(--color-neon-cyan-dim)] rounded text-[10px] hover:bg-[var(--color-neon-cyan)] hover:text-black transition-all opacity-0"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="currentColor"><path d="M5 3l14 9-14 9V3z"/></svg>
        Gravity
      </a>
      <a
        id="shooting-btn"
        href="/shooting-game.html"
        class="hidden items-center gap-1.5 px-2 py-0.5 border border-[var(--color-neon-magenta)] text-[var(--color-neon-magenta)] bg-[var(--color-neon-magenta-dim)] rounded text-[10px] hover:bg-[var(--color-neon-magenta)] hover:text-white transition-all opacity-0"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="currentColor"><path d="M5 3l14 9-14 9V3z"/></svg>
        Danmaku
      </a>
    </div>
  </div>
  
  <div class="flex gap-6">
    {socialLinks.map((link) => (
      <a href={link.url} target="_blank" rel="noopener" class="hover:text-white hover:text-shadow-[0_0_8px_rgba(0,255,213,0.8)] transition-all">
        {link.name}
      </a>
    ))}
  </div>
</footer>

<script>
  // イースターエッグのロジック: 10回連続クリックで隠しボタンが出現
  const secretBtn = document.getElementById("secret-btn");
  const gravityBtn = document.getElementById("gravity-btn");
  const shootingBtn = document.getElementById("shooting-btn");

  let clickCount = 0;
  let resetTimer: ReturnType<typeof setTimeout>;
  let hideTimer: ReturnType<typeof setTimeout>;

  function showGameBtns() {
    clearTimeout(hideTimer);
    
    [gravityBtn, shootingBtn].forEach((btn) => {
      if (!btn) return;
      btn.style.display = "flex";
      // 少し遅延させてopacityを上げることでフワッと出す
      requestAnimationFrame(() => {
        setTimeout(() => {
          btn.style.opacity = "1";
        }, 10);
      });
    });

    // 10秒後に再び隠す
    hideTimer = setTimeout(() => {
      [gravityBtn, shootingBtn].forEach((btn) => {
        if (!btn) return;
        btn.style.opacity = "0";
        setTimeout(() => {
           btn.style.display = "none";
        }, 300); // fade duration
      });
    }, 10000);
  }

  secretBtn?.addEventListener("click", () => {
    clickCount++;
    clearTimeout(resetTimer);
    
    // 10回達成！
    if (clickCount >= 10) {
      clickCount = 0;
      showGameBtns();
    }
    
    // 2.5秒間クリックが途切れたらカウントリセット
    resetTimer = setTimeout(() => {
      clickCount = 0;
    }, 2500);
  });
</script>
