---
import SkillBadge from "./SkillBadge.astro";

export interface Props {
  title: string;
  description: string;
  tags: string[];
  featured?: boolean;
  link?: string;
}

const { title, description, tags, link } = Astro.props;
---

<article class={`group flex flex-col rounded-lg border border-border-default bg-bg-secondary p-5 transition-colors hover:bg-bg-card${link ? ' cursor-pointer' : ''}`}>
  {link && (
    <a href={link} class="absolute inset-0" aria-label={title} />
  )}
  <h3 class="mb-2 text-sm font-semibold text-text-primary">
    {title}
  </h3>

  <p class="mb-4 flex-1 text-sm leading-relaxed text-text-muted">
    {description}
  </p>

  <div class="flex flex-wrap gap-1.5">
    {tags.map((tag) => <SkillBadge text={tag} />)}
  </div>
</article>
