---
import SkillBadge from "./SkillBadge.astro";

export interface Props {
  slug: string;
  title: string;
  description: string;
  tags: string[];
  link?: string;
  github?: string;
}

const { slug, title, description, tags, link, github } = Astro.props;
---

<article class="group relative flex flex-col rounded-lg border border-border-default bg-bg-secondary p-5 transition-colors hover:bg-bg-card">
  {/* カード全体をクリックで詳細ページへ */}
  <a href={`/projects/${slug}`} class="absolute inset-0 rounded-lg" aria-label={`${title} の詳細を見る`} />

  <div class="mb-2 flex items-start justify-between gap-2">
    <h3 class="text-sm font-semibold text-text-primary">
      {title}
    </h3>
    {/* 外部リンクボタン（絶対配置リンクより上に重ねる） */}
    <div class="relative z-10 flex shrink-0 items-center gap-2">
      {github && (
        <a
          href={github}
          target="_blank"
          rel="noopener"
          aria-label="GitHub"
          class="text-text-muted transition-colors hover:text-text-primary"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 .5C5.6.5.5 5.6.5 12c0 5.1 3.3 9.4 7.9 10.9.6.1.8-.2.8-.6v-2c-3.2.7-3.9-1.5-3.9-1.5-.5-1.3-1.3-1.7-1.3-1.7-1-.7.1-.7.1-.7 1.1.1 1.7 1.2 1.7 1.2 1 1.7 2.6 1.2 3.2.9.1-.7.4-1.2.7-1.5-2.5-.3-5.2-1.3-5.2-5.7 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0C17.3 5.5 18.3 5.8 18.3 5.8c.6 1.6.2 2.8.1 3.1.8.8 1.2 1.8 1.2 3.1 0 4.4-2.7 5.4-5.2 5.7.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6C20.2 21.4 23.5 17.1 23.5 12 23.5 5.6 18.4.5 12 .5z"/>
          </svg>
        </a>
      )}
      {link && (
        <a
          href={link}
          target="_blank"
          rel="noopener"
          aria-label="外部リンク"
          class="text-text-muted transition-colors hover:text-text-primary"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
      )}
    </div>
  </div>

  <p class="mb-4 flex-1 text-sm leading-relaxed text-text-muted">
    {description}
  </p>

  <div class="flex flex-wrap gap-1.5">
    {tags.map((tag) => <SkillBadge text={tag} />)}
  </div>
</article>
