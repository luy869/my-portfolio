---
import CyberBentoCard from "./CyberBentoCard.astro";

interface Props {
  slug: string;
  title: string;
  description: string;
  tags?: string[];
  link?: string;
  github?: string;
}

const { slug, title, description, tags = [] } = Astro.props;

// カードの色をランダムっぽくするためタグ文字などの長さに応じて発光色を変える
const glowColors: ('cyan' | 'magenta' | 'yellow')[] = ['cyan', 'magenta', 'yellow'];
const glowColor = glowColors[title.length % 3] as 'cyan' | 'magenta' | 'yellow';
---

<CyberBentoCard href={`/projects/${slug}`} glowColor={glowColor} className="flex flex-col justify-between h-full group !p-6 aspect-square sm:aspect-auto sm:min-h-[280px]">
  
  <div class="z-10 relative">
    <!-- タイトル -->
    <h3 class="text-xl md:text-2xl font-bold tracking-tight text-white mb-3 font-mono group-hover:text-[var(--color-neon-cyan)] transition-colors">
      {title}
    </h3>
    <p class="text-sm text-[var(--color-text-secondary)] line-clamp-3 leading-relaxed">
      {description}
    </p>
  </div>
  
  <div class="z-10 mt-6 flex flex-col gap-4">
    <!-- タグ -->
    {tags.length > 0 && (
      <div class="flex flex-wrap gap-2">
        {tags.slice(0, 3).map((tag) => (
          <span class="rounded bg-[var(--color-bg-base)] px-2 py-1 text-[0.65rem] font-mono text-[var(--color-text-primary)] border border-[var(--color-border-default)] shadow-[inset_0_0_5px_rgba(255,255,255,0.02)]">
            # {tag}
          </span>
        ))}
      </div>
    )}
    
    <!-- サイバーな矢印アイコン -->
    <div class="flex items-center justify-between border-t border-[var(--color-border-default)] pt-4 mt-2">
      <span class="text-[0.65rem] uppercase tracking-[0.2em] font-mono text-[var(--color-text-muted)] group-hover:text-white transition-colors">Explore_</span>
      <div class="w-8 h-8 rounded-full border border-[var(--color-border-default)] flex items-center justify-center group-hover:bg-[var(--color-neon-cyan-dim)] group-hover:border-[var(--color-neon-cyan)] transition-all transform group-hover:-rotate-45">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" class="stroke-[var(--color-text-muted)] group-hover:stroke-[var(--color-neon-cyan)] transition-colors" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14"></path>
          <path d="M12 5l7 7-7 7"></path>
        </svg>
      </div>
    </div>
  </div>
  
  <!-- バックグラウンド装飾（右上の薄いロゴ的なもの） -->
  <div class="absolute -right-4 -top-4 opacity-5 group-hover:opacity-10 transition-opacity pointer-events-none transform rotate-12 scale-150">
    <svg xmlns="http://www.w3.org/2000/svg" width="100" height="100" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
      <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
    </svg>
  </div>
</CyberBentoCard>
