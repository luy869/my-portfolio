---
import { getCollection, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import CyberBentoCard from "../../components/ui/CyberBentoCard.astro";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<Layout title={`${project.data.title} | rui`} description={project.data.description}>
  
  <div class="grid-overlay pointer-events-none fixed inset-0 z-[-1]"></div>
  <div class="scanlines pointer-events-none fixed inset-0 z-[-1]"></div>

  <div class="relative z-10 px-4 md:px-8 max-w-4xl mx-auto pb-20 pt-8 flex flex-col gap-6">
    <Header />

    <!-- 戻るリンク -->
    <a href="/#projects" class="inline-flex items-center gap-2 font-mono text-xs tracking-widest uppercase text-[var(--color-neon-cyan)] hover:text-white transition-colors w-fit border border-[var(--color-neon-cyan)]/30 bg-[var(--color-neon-cyan-dim)] px-4 py-2 rounded">
      &larr; cd ../
    </a>

    <!-- ヘッダーカード -->
    <CyberBentoCard glowColor="magenta" className="mb-4 !p-6 md:!p-10 relative overflow-hidden">
      <div class="absolute -right-10 -bottom-10 opacity-5 pointer-events-none text-9xl font-bold italic mix-blend-overlay">
        {project.data.title.substring(0, 2).toUpperCase()}
      </div>

      <div class="flex flex-col gap-6 relative z-10">
        
        {project.data.tags.length > 0 && (
          <div class="flex flex-wrap gap-2">
            {project.data.tags.map(tag => (
              <span class="rounded bg-[var(--color-bg-base)] px-2.5 py-1 text-xs font-mono font-semibold text-white border border-[var(--color-border-default)] shadow-[0_0_10px_rgba(255,255,255,0.05)]">
                # {tag}
              </span>
            ))}
          </div>
        )}
        
        <div>
          <h1 class="text-3xl md:text-5xl font-bold tracking-tight text-white mt-2 mb-4 font-mono">
            {project.data.title}
          </h1>
          <p class="text-[var(--color-text-secondary)] text-sm md:text-base leading-relaxed">
            {project.data.description}
          </p>
        </div>

        <!-- リンク -->
        {(project.data.github || project.data.link) && (
          <div class="flex flex-wrap gap-4 mt-4">
            {project.data.github && (
              <a href={project.data.github} target="_blank" rel="noopener" class="inline-flex items-center justify-center font-mono text-xs tracking-widest uppercase text-white hover:text-[var(--color-neon-cyan)] hover:border-[var(--color-neon-cyan)] hover:shadow-[0_0_15px_rgba(0,255,213,0.3)] transition-all border border-[var(--color-border-default)] bg-[var(--color-bg-base)] px-6 py-3 rounded">
                [ GitHub ]
              </a>
            )}
             {project.data.link && (
              <a href={project.data.link} target="_blank" rel="noopener" class="inline-flex items-center justify-center font-mono text-xs tracking-widest uppercase text-[var(--color-bg-base)] bg-[var(--color-neon-cyan)] hover:bg-white transition-all shadow-[0_0_15px_rgba(0,255,213,0.4)] px-6 py-3 rounded font-bold">
                Run App &gt;
              </a>
            )}
          </div>
        )}
      </div>
    </CyberBentoCard>

    <!-- 本文 -->
    <CyberBentoCard glowColor="none" className="prose-container !p-6 md:!p-10">
      <Content />
    </CyberBentoCard>

    <Footer />
  </div>
</Layout>

<style is:global>
  .prose-container {
    color: var(--color-text-secondary);
    font-size: 0.95rem;
    line-height: 1.8;
  }
  
  .prose-container h2 {
    color: white;
    font-size: 1.4rem;
    font-weight: 700;
    margin-top: 3rem;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-border-neon);
    font-family: var(--font-mono);
    text-shadow: 0 0 10px rgba(0,255,213,0.3);
  }
  
  .prose-container h2::before {
    content: "> ";
    color: var(--color-neon-cyan);
  }

  .prose-container h3 {
    color: white;
    font-size: 1.1rem;
    font-weight: 600;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    font-family: var(--font-mono);
  }
  
  .prose-container h3::before {
    content: "## ";
    color: var(--color-neon-magenta);
  }

  .prose-container p {
    margin-bottom: 1.25rem;
  }
  
  .prose-container a {
    color: var(--color-neon-cyan);
    text-decoration: none;
    border-bottom: 1px dashed var(--color-neon-cyan);
    transition: all 0.2s;
  }

  .prose-container a:hover {
    color: white;
    border-bottom-color: white;
    text-shadow: 0 0 8px rgba(0,255,213,0.8);
  }
  
  .prose-container ul {
    list-style-type: none;
    padding-left: 0;
    margin-bottom: 1.5rem;
  }
  
  .prose-container li {
    position: relative;
    padding-left: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .prose-container li::before {
    content: "-";
    position: absolute;
    left: 0;
    color: var(--color-neon-cyan);
    font-weight: bold;
  }
  
  .prose-container strong {
    color: white;
    font-weight: 600;
  }
  
  .prose-container code {
    background-color: var(--color-bg-base);
    color: var(--color-neon-magenta);
    padding: 0.2rem 0.4rem;
    border-radius: 0.25rem;
    font-size: 0.85rem;
    font-family: var(--font-mono);
    border: 1px solid var(--color-border-default);
  }
  
  .prose-container pre {
    background-color: var(--color-bg-base);
    border: 1px solid var(--color-border-default);
    border-radius: 0.5rem;
    padding: 1rem;
    overflow-x: auto;
    margin-bottom: 1.5rem;
  }
  
  .prose-container pre code {
    background-color: transparent;
    padding: 0;
    border: none;
    color: inherit;
    font-size: 0.85rem;
  }
  
  .prose-container blockquote {
    border-left: 2px solid var(--color-neon-magenta);
    background: rgba(255,0,170,0.05);
    padding: 1rem;
    color: var(--color-text-secondary);
    font-style: italic;
    margin-bottom: 1.5rem;
    border-radius: 0 0.5rem 0.5rem 0;
  }
</style>
